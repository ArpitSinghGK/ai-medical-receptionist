# Copy to .env and fill in. Never commit real secrets.

ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://localhost/medreception

# --- Anthropic (conversation brain) ---
ANTHROPIC_API_KEY=sk-ant-...
# Fast model for the real-time phone turn; swap to claude-sonnet-5 for
# tougher triage where latency is looser.
LLM_MODEL=claude-haiku-4-5
LLM_MAX_TOKENS=1024

# --- Telephony (Twilio) ---
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+15551234567
# Public URL Twilio reaches this service on (media streams use wss://).
PUBLIC_BASE_URL=https://your-app.example.com

# --- Speech ---
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# --- Notifications ---
SENDGRID_API_KEY=SG...
NOTIFICATIONS_FROM_EMAIL=noreply@example.com

# --- Security ---
# 32-byte urlsafe base64 Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PHI_ENCRYPTION_KEY=
JWT_SECRET=change-me
JWT_TTL_MINUTES=60
